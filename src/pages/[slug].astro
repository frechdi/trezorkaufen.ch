---
import BaseLayout from '../layouts/BaseLayout.astro';
import StarRating from '../components/StarRating.astro';
import { wallets, getWalletBySlug } from '../content/wallets';
import type { Wallet } from '../content/wallets';

export function getStaticPaths() {
  return wallets.map(wallet => ({
    params: { slug: wallet.slug },
  }));
}

const { slug } = Astro.params;
const wallet = getWalletBySlug(slug as string)!;

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "Product",
    "name": wallet.name,
    "brand": {
      "@type": "Brand",
      "name": wallet.brand
    },
    "image": `https://trezorkaufen.ch${wallet.image}`,
    "offers": {
      "@type": "Offer",
      "price": wallet.priceValue,
      "priceCurrency": "CHF",
      "availability": "https://schema.org/InStock",
      "url": wallet.affiliateUrl
    }
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": wallet.rating,
    "bestRating": 10,
    "worstRating": 0
  },
  "author": {
    "@type": "Organization",
    "name": "TrezorKaufen.ch"
  },
  "publisher": {
    "@type": "Organization",
    "name": "TrezorKaufen.ch"
  },
  "datePublished": "2026-03-01",
  "dateModified": "2026-03-22"
};

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Wallets", url: "/vergleich" },
  { name: wallet.name, url: `/${wallet.slug}` }
];

const relatedWallets = wallets
  .filter(w => w.slug !== wallet.slug)
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 3);
---

<BaseLayout
  title={wallet.metaTitle}
  description={wallet.metaDesc}
  ogType="article"
  jsonLd={reviewSchema}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-navy-950 to-navy-900 border-b border-navy-700/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-shrink-0">
          <img src={wallet.image} alt={`${wallet.name} Hardware Wallet`} class="h-40 w-auto" />
        </div>
        <div class="text-center md:text-left">
          <span class="text-gray-400 text-sm">{wallet.brand}</span>
          <h1 class="text-3xl sm:text-4xl font-extrabold text-white mt-1 mb-3">{wallet.name} Test 2026</h1>
          <div class="flex items-center justify-center md:justify-start gap-3 mb-4">
            <StarRating rating={wallet.rating} />
            <span class="text-amber-400 font-bold text-lg">{wallet.rating}/10</span>
          </div>
          <p class="text-gray-300 text-sm leading-relaxed mb-4">{wallet.summary}</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
            <a href={wallet.affiliateUrl} rel="nofollow sponsored" target="_blank" class="cta-button bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-3 px-6 rounded-lg text-sm inline-flex items-center justify-center gap-2">
              <span>Jetzt für {wallet.price} kaufen</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
            <a href="/vergleich" class="border border-navy-600 hover:border-trezor-500/50 text-gray-300 hover:text-trezor-400 font-medium py-3 px-6 rounded-lg text-sm transition-colors text-center">
              Alle Wallets vergleichen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Pros & Cons -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-trezor-500/5 border border-trezor-500/20 rounded-xl p-5">
            <h2 class="text-trezor-400 font-semibold mb-3 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Vorteile
            </h2>
            <ul class="space-y-2">
              {wallet.pros.map(pro => (
                <li class="text-gray-300 text-sm flex items-start gap-2">
                  <span class="text-trezor-400 mt-0.5 flex-shrink-0">+</span>
                  {pro}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-red-500/5 border border-red-500/20 rounded-xl p-5">
            <h2 class="text-red-400 font-semibold mb-3 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              Nachteile
            </h2>
            <ul class="space-y-2">
              {wallet.cons.map(con => (
                <li class="text-gray-300 text-sm flex items-start gap-2">
                  <span class="text-red-400 mt-0.5 flex-shrink-0">-</span>
                  {con}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Review Sections -->
        {wallet.sections.map(section => (
          <div>
            <h2 class="text-xl font-bold text-white mb-3">{section.heading}</h2>
            <p class="text-gray-300 text-sm leading-relaxed">{section.content}</p>
          </div>
        ))}

        <!-- Verdict -->
        <div class="bg-gradient-to-r from-trezor-500/10 to-trezor-600/10 border border-trezor-500/20 rounded-xl p-6">
          <h2 class="text-xl font-bold text-white mb-3">Fazit: {wallet.name}</h2>
          <p class="text-gray-300 text-sm leading-relaxed mb-4">{wallet.verdict}</p>
          <a href={wallet.affiliateUrl} rel="nofollow sponsored" target="_blank" class="cta-button inline-flex items-center gap-2 bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-3 px-6 rounded-lg text-sm">
            {wallet.name} für {wallet.price} kaufen
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="bg-navy-800 border border-navy-700 rounded-xl p-5 sticky top-20">
          <h3 class="text-white font-semibold mb-4">Technische Daten</h3>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between">
              <dt class="text-gray-400">Preis</dt>
              <dd class="text-white font-medium">{wallet.price}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-400">Bewertung</dt>
              <dd class="text-amber-400 font-medium">{wallet.rating}/10</dd>
            </div>
            <div class="border-t border-navy-700 pt-3 flex justify-between">
              <dt class="text-gray-400">Bluetooth</dt>
              <dd class={wallet.specs.bluetooth ? 'text-trezor-400' : 'text-gray-500'}>{wallet.specs.bluetooth ? 'Ja' : 'Nein'}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-400">Touchscreen</dt>
              <dd class={wallet.specs.touchscreen ? 'text-trezor-400' : 'text-gray-500'}>{wallet.specs.touchscreen ? 'Ja' : 'Nein'}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-400">Open Source</dt>
              <dd class={wallet.specs.openSource ? 'text-trezor-400' : 'text-gray-500'}>{wallet.specs.openSource ? 'Ja' : 'Nein'}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-400">Coins</dt>
              <dd class="text-white">{wallet.specs.coins}</dd>
            </div>
            <div class="border-t border-navy-700 pt-3 flex justify-between">
              <dt class="text-gray-400">Abmessungen</dt>
              <dd class="text-gray-300 text-xs">{wallet.specs.dimensions}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-400">Gewicht</dt>
              <dd class="text-gray-300">{wallet.specs.weight}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-400">Anschluss</dt>
              <dd class="text-gray-300 text-xs">{wallet.specs.connectivity}</dd>
            </div>
            {wallet.specs.battery && (
              <div class="flex justify-between">
                <dt class="text-gray-400">Akku</dt>
                <dd class="text-gray-300 text-xs">{wallet.specs.battery}</dd>
              </div>
            )}
            <div class="flex justify-between">
              <dt class="text-gray-400">Sicherheitschip</dt>
              <dd class="text-gray-300 text-xs">{wallet.specs.securityChip}</dd>
            </div>
          </dl>

          <a href={wallet.affiliateUrl} rel="nofollow sponsored" target="_blank" class="cta-button mt-5 block w-full text-center bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-2.5 px-4 rounded-lg text-sm">
            Jetzt kaufen &ndash; {wallet.price}
          </a>
        </div>
      </div>
    </div>

    <!-- Related Wallets -->
    <div class="mt-12">
      <h2 class="text-xl font-bold text-white mb-6">Weitere Hardware Wallets im Test</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {relatedWallets.map(rw => (
          <a href={`/${rw.slug}`} class="bg-navy-800 border border-navy-700 rounded-xl p-4 hover:border-trezor-500/30 transition-colors group">
            <div class="flex items-center gap-3">
              <img src={rw.image} alt={rw.name} class="w-10 h-10 object-contain" loading="lazy" />
              <div>
                <span class="text-white font-medium text-sm group-hover:text-trezor-400 transition-colors">{rw.name}</span>
                <div class="flex items-center gap-2">
                  <span class="text-amber-400 text-xs font-medium">{rw.rating}/10</span>
                  <span class="text-gray-500 text-xs">{rw.price}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
