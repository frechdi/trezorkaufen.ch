---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogPosts } from '../content/wallets';

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" }
];
---

<BaseLayout
  title="Blog – Trezor News, Tests & Tipps | TrezorKaufen.ch"
  description="Aktuelle News, Testberichte und Anleitungen rund um Trezor Hardware Wallets und Krypto-Sicherheit in der Schweiz."
  breadcrumbs={breadcrumbs}
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-extrabold text-white mb-8">Blog</h1>

    <div class="space-y-6">
      {blogPosts.map(post => (
        <article class="bg-navy-800 border border-navy-700 rounded-xl p-6 hover:border-trezor-500/30 transition-colors">
          <time class="text-xs text-gray-500">{new Date(post.date).toLocaleDateString('de-CH', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <h2 class="text-lg font-bold text-white mt-1 mb-2">
            <a href={`/blog/${post.slug}`} class="hover:text-trezor-400 transition-colors">{post.title}</a>
          </h2>
          <p class="text-gray-400 text-sm leading-relaxed mb-3">{post.excerpt}</p>
          <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-1 text-trezor-400 hover:text-trezor-500 text-sm font-medium transition-colors">
            Weiterlesen
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
