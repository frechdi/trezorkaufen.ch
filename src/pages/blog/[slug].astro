---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts, getBlogPostBySlug } from '../../content/wallets';

export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = getBlogPostBySlug(slug as string)!;

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog" },
  { name: post.title.substring(0, 40) + '...', url: `/blog/${post.slug}` }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "datePublished": post.date,
  "dateModified": post.date,
  "author": { "@type": "Organization", "name": "TrezorKaufen.ch" },
  "publisher": { "@type": "Organization", "name": "TrezorKaufen.ch" }
};
---

<BaseLayout
  title={post.metaTitle}
  description={post.metaDesc}
  ogType="article"
  jsonLd={articleSchema}
  breadcrumbs={breadcrumbs}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <time class="text-xs text-gray-500">{new Date(post.date).toLocaleDateString('de-CH', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    <h1 class="text-3xl font-extrabold text-white mt-2 mb-6">{post.title}</h1>
    <div class="prose prose-invert max-w-none">
      <p class="text-gray-300 leading-relaxed whitespace-pre-line">{post.content}</p>
    </div>

    <!-- CTA -->
    <div class="mt-8 bg-gradient-to-r from-trezor-500/10 to-trezor-600/10 border border-trezor-500/20 rounded-xl p-6 text-center">
      <h2 class="text-lg font-bold text-white mb-2">Trezor Hardware Wallet kaufen?</h2>
      <p class="text-gray-300 text-sm mb-4">Vergleiche die besten Trezor-Modelle 2026 in unserem ausführlichen Test.</p>
      <a href="/vergleich" class="cta-button inline-block bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-2.5 px-5 rounded-lg text-sm">
        Zum Wallet-Vergleich
      </a>
    </div>

    <!-- Back -->
    <div class="text-center mt-6">
      <a href="/blog" class="inline-flex items-center gap-1 text-trezor-400 hover:text-trezor-500 text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Zurück zum Blog
      </a>
    </div>
  </article>
</BaseLayout>
