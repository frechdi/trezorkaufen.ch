---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';
import { comparisons, getComparisonBySlug, getWalletBySlug } from '../../content/wallets';

export function getStaticPaths() {
  return comparisons.map(comp => ({
    params: { slug: comp.slug },
  }));
}

const { slug } = Astro.params;
const comparison = getComparisonBySlug(slug as string)!;
const wallet1 = getWalletBySlug(comparison.wallet1Slug)!;
const wallet2 = getWalletBySlug(comparison.wallet2Slug)!;

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Vergleich", url: "/vergleich" },
  { name: comparison.title.split('–')[0].trim(), url: `/vergleich/${comparison.slug}` }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": comparison.title,
  "datePublished": "2026-03-01",
  "dateModified": "2026-03-22",
  "author": { "@type": "Organization", "name": "TrezorKaufen.ch" },
  "publisher": { "@type": "Organization", "name": "TrezorKaufen.ch" }
};
---

<BaseLayout
  title={comparison.metaTitle}
  description={comparison.metaDesc}
  ogType="article"
  jsonLd={articleSchema}
  breadcrumbs={breadcrumbs}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-6">{comparison.title}</h1>
    <p class="text-gray-300 leading-relaxed mb-8">{comparison.intro}</p>

    <!-- Head-to-Head Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
      {[wallet1, wallet2].map(w => (
        <div class="bg-navy-800 border border-navy-700 rounded-xl p-5 text-center">
          <img src={w.image} alt={w.name} class="h-20 w-auto mx-auto mb-3" loading="lazy" />
          <h3 class="text-white font-bold text-lg">{w.name}</h3>
          <p class="text-gray-400 text-sm mb-2">{w.brand}</p>
          <div class="flex items-center justify-center gap-2 mb-2">
            <StarRating rating={w.rating} />
            <span class="text-amber-400 font-bold">{w.rating}/10</span>
          </div>
          <p class="text-white text-xl font-bold mb-3">{w.price}</p>
          <div class="grid grid-cols-2 gap-2 text-xs mb-4">
            <div class="bg-navy-900/50 rounded px-2 py-1.5">
              <span class="text-gray-400 block">Bluetooth</span>
              <span class={w.specs.bluetooth ? 'text-trezor-400' : 'text-gray-500'}>{w.specs.bluetooth ? 'Ja' : 'Nein'}</span>
            </div>
            <div class="bg-navy-900/50 rounded px-2 py-1.5">
              <span class="text-gray-400 block">Touchscreen</span>
              <span class={w.specs.touchscreen ? 'text-trezor-400' : 'text-gray-500'}>{w.specs.touchscreen ? 'Ja' : 'Nein'}</span>
            </div>
            <div class="bg-navy-900/50 rounded px-2 py-1.5">
              <span class="text-gray-400 block">Open Source</span>
              <span class={w.specs.openSource ? 'text-trezor-400' : 'text-gray-500'}>{w.specs.openSource ? 'Ja' : 'Nein'}</span>
            </div>
            <div class="bg-navy-900/50 rounded px-2 py-1.5">
              <span class="text-gray-400 block">Coins</span>
              <span class="text-white">{w.specs.coins}</span>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <a href={w.affiliateUrl} rel="nofollow sponsored" target="_blank" class="cta-button block w-full text-center bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-2 px-4 rounded-lg text-sm">
              Jetzt kaufen
            </a>
            <a href={`/${w.slug}`} class="block w-full text-center text-trezor-400 hover:text-trezor-500 text-sm font-medium transition-colors">
              Testbericht lesen
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Comparison Sections -->
    {comparison.sections.map(section => (
      <div class="mb-8">
        <h2 class="text-xl font-bold text-white mb-3">{section.heading}</h2>
        <p class="text-gray-300 text-sm leading-relaxed">{section.content}</p>
      </div>
    ))}

    <!-- Verdict -->
    <div class="bg-gradient-to-r from-trezor-500/10 to-trezor-600/10 border border-trezor-500/20 rounded-xl p-6 mb-8">
      <h2 class="text-xl font-bold text-white mb-3">Unser Fazit</h2>
      <p class="text-gray-300 text-sm leading-relaxed mb-4">{comparison.verdict}</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={wallet1.affiliateUrl} rel="nofollow sponsored" target="_blank" class="cta-button bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-2.5 px-5 rounded-lg text-sm text-center">
          {wallet1.name} kaufen &ndash; {wallet1.price}
        </a>
        <a href={wallet2.affiliateUrl} rel="nofollow sponsored" target="_blank" class="cta-button bg-trezor-500 hover:bg-trezor-400 text-white font-semibold py-2.5 px-5 rounded-lg text-sm text-center">
          {wallet2.name} kaufen &ndash; {wallet2.price}
        </a>
      </div>
    </div>

    <div class="text-center">
      <a href="/vergleich" class="inline-flex items-center gap-1 text-trezor-400 hover:text-trezor-500 text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Zurück zur Vergleichsübersicht
      </a>
    </div>
  </article>
</BaseLayout>
